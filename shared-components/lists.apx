list navigation-bar (
    name: Navigation Bar

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 20
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 30
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

)

list navigation-menu (
    name: Navigation Menu

    entry chatbots (
        label: Chatbots
        icon {
            imageIconCssClasses: fa-table
        }
        layout {
            sequence: 80
        }
        isCurrent {
            type: pages
            pages: [
                8
                9
            ]
        }
        link {
            target: {
                page: 8
            }
        }
    )

    entry home (
        label: Home
        icon {
            imageIconCssClasses: fa-home
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 1
            }
        }
    )

    entry low-code-agent-features (
        label: Low-Code AI Assistant
        icon {
            imageIconCssClasses: fa-chatbot
        }
        layout {
            sequence: 20
        }
        isCurrent {
            type: pages
            pages: 2
        }
        link {
            target: {
                page: 2
            }
        }
    )

    entry low-code-agents-tools (
        label: Low Code Agents Tools
        icon {
            imageIconCssClasses: fa-ai
        }
        layout {
            sequence: 30
        }
        isCurrent {
            type: pages
            pages: 3
        }
        link {
            target: {
                page: 3
            }
        }
    )

)

