page 3 (
    name: Low Code AI Agent
    alias: LOW-CODE-AGENTS-TOOLS
    title: Low Code AI Agent
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region new (
        name: APEX AI Agent
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--showIcon
                t-Region--scrollBody
            ]
            icon: fa-ai
        }
        advanced {
            htmlDomId: region-chatbot
        }
    )

    button new (
        buttonName: REFRESH_AGENT
        label: Refresh Agent
        layout {
            sequence: 10
            region: @new
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-refresh
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction new (
        name: Refresh Agent
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @new
        }

        action native-open-ai-assistant (
            action: showAiAssistant
            genAI {
                agent: @sample-ai-agents
            }
            appearance {
                displayAs: inline
                containerSelector: #region-chatbot
            }
            execution {
                sequence: 10
            }
            advanced {
                initJavaScriptFunction:
                    ```javascript-browser
                     function( options ) {
                        window.chatModel?.destroy()
                        window.chatView?.destroy()
                        
                        options.useChatContext = ( chatModel, chatView ) => {
                            window.chatModel = chatModel;
                            window.chatView = chatView;
                        };
                    
                        return options;
                    }
                    ```
            }
        )

    )

)

