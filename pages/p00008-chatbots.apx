page 8 (
    name: Chatbots
    alias: CHATBOTS
    title: Chatbots
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region chatbots (
        name: Chatbots
        type: classicReport
        source {
            location: localDatabase
            tableName: CB_CHATBOTS
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        messages {
            whenNoDataFound: No data found.
        }

        column CREATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
        )

        column CURRENT_SUMMARY (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Current Summary
            }
            layout {
                sequence: 6
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                alignment: center
            }
            layout {
                sequence: 0
                columnAlignment: center
            }
            link {
                target: {
                    page: 9
                    items: {
                        P9_ID: \#ID#\
                    }
                    action: resetPagination
                }
                linkText: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
            }
            sorting {
                sortable: false
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 2
            }
            sorting {
                defaultSequence: 1
            }
        )

        column PROMPT (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Prompt
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column SUMMARY_PROMPT (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Summary Prompt
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column WELCOME_MESSAGE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Welcome Message
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 10
            region: @chatbots
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9
                clearCache: 9
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @chatbots
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @chatbots
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

